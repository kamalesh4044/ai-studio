# ----------------------------
# Chat (recommended)
# ----------------------------
# Point this to OpenAI-compatible or custom REST endpoint.
CHAT_ENDPOINT=http://127.0.0.1:8000/chat
CHAT_API_KEY=
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct
CHAT_TEMPERATURE=0.7
CHAT_MAX_TOKENS=1024

# ----------------------------
# Image generation (recommended)
# ----------------------------
IMAGE_ENDPOINT=http://127.0.0.1:8000/generate-image
IMAGE_API_KEY=
IMAGE_MODEL=stabilityai/sdxl-turbo
IMAGE_STEPS=4

# ----------------------------
# Image-to-video (optional)
# Keep empty to use built-in mock fallback.
# ----------------------------
VIDEO_ENDPOINT=
VIDEO_API_KEY=
VIDEO_MODEL=stabilityai/stable-video-diffusion-img2vid-xt

# ----------------------------
# Two-image transition (optional)
# Keep empty to use built-in mock fallback.
# ----------------------------
TRANSITION_ENDPOINT=
TRANSITION_API_KEY=
TRANSITION_MODEL=google-research/frame-interpolation

# Legacy aliases still supported by routes:
# LLAMA3_ENDPOINT / LLAMA3_API_KEY
# SDXL_ENDPOINT / SDXL_API_KEY
# SVD_ENDPOINT / SVD_API_KEY
# FILM_ENDPOINT / FILM_API_KEY
